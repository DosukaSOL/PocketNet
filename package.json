{
  "name": "pocketnet",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --watchAll=false",
    "format": "prettier --write .",
    "check:secrets": "node scripts/secret-scan.mjs",
    "qa": "npm run typecheck && npm run lint && npm run test && npm run check:secrets"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@supabase/supabase-js": "^2.105.4",
    "expo": "^55.0.24",
    "expo-audio": "~55.0.14",
    "expo-constants": "~55.0.16",
    "expo-file-system": "~55.0.20",
    "expo-image": "~55.0.10",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.14",
    "expo-linking": "~55.0.15",
    "expo-router": "^55.0.14",
    "expo-screen-orientation": "~55.0.15",
    "expo-splash-screen": "~55.0.21",
    "expo-status-bar": "~55.0.6",
    "lucide-react-native": "^0.556.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.7.4",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/node": "25.8.0",
    "@types/react": "^19.2.7",
    "eslint": "^9.39.1",
    "eslint-config-expo": "~55.0.1",
    "jest": "~29.7.0",
    "jest-expo": "^55.0.9",
    "prettier": "^3.7.4",
    "react-test-renderer": "19.2.0",
    "typescript": "^5.9.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/tests/setup.ts"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.expo/"
    ]
  }
}
